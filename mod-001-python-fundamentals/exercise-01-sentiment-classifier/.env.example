# Model Configuration
MODEL_NAME=bert-base-uncased
MODEL_CACHE_DIR=./models/cache
MAX_SEQUENCE_LENGTH=512

# Training Configuration
BATCH_SIZE=32
LEARNING_RATE=0.001
NUM_EPOCHS=10
DEVICE=cpu

# Data Configuration
DATA_DIR=./data
TRAIN_FILE=train.csv
VAL_FILE=val.csv
TEST_FILE=test.csv

# Logging
LOG_LEVEL=INFO
LOG_FILE=training.log
