{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Model API service overview — request rate, latency, errors, replicas",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "id": 1,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"model-api\"}[1m])) by (method, status)",
          "legendFormat": "{{method}} {{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "title": "Error Rate (5xx %)",
      "type": "stat",
      "id": 2,
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"model-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"model-api\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      }
    },
    {
      "title": "Active Replicas",
      "type": "stat",
      "id": 3,
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_available{deployment=\"model-api\"}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latency p50 / p95 / p99",
      "type": "timeseries",
      "id": 4,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"model-api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"model-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"model-api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "CPU Utilization (per pod)",
      "type": "timeseries",
      "id": 5,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{pod=~\"model-api-.*\",container=\"model-api\"}[2m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Memory Working Set (per pod)",
      "type": "timeseries",
      "id": 6,
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{pod=~\"model-api-.*\",container=\"model-api\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "title": "Inference Latency p95 (ms)",
      "type": "timeseries",
      "id": 7,
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum(rate(ml_inference_duration_seconds_bucket[5m])) by (le, model_version))",
          "legendFormat": "{{model_version}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ms"}}
    },
    {
      "title": "HPA Current vs Desired Replicas",
      "type": "timeseries",
      "id": 8,
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{horizontalpodautoscaler=\"model-api\"}",
          "legendFormat": "current",
          "refId": "A"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{horizontalpodautoscaler=\"model-api\"}",
          "legendFormat": "desired",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["ml", "model-api", "project-02"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "",
  "title": "Model API — Overview",
  "uid": "model-api-overview",
  "version": 1
}
