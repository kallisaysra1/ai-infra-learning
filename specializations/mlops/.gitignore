data/
datasets/
*.csv
*.parquet
*.feather
*.arrow
*.json
*.jsonl
*.tfrecord
*.h5
*.hdf5

# Exceptions: Keep sample/demo data
!**/sample_data/
!**/demo_data/
!**/*_sample.csv
!**/*_demo.json

# ==============================================================================
