# ==============================================================================
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# ==============================================================================
# IDEs
# ==============================================================================
# PyCharm
.idea/
*.iml

# VSCode
.vscode/
*.code-workspace

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# ==============================================================================
