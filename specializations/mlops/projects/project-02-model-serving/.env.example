# Application Configuration
APP_NAME=model-serving-platform
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=30
API_RELOAD=false

# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/models
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600
REDIS_MAX_CONNECTIONS=50

# Model Storage Configuration
MODEL_STORAGE_TYPE=s3
MODEL_STORAGE_BUCKET=models
MODEL_STORAGE_ENDPOINT=http://localhost:9000
MODEL_STORAGE_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Vault Configuration
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your-vault-token-here
VAULT_NAMESPACE=model-serving
VAULT_AUTH_METHOD=kubernetes
VAULT_ROLE=model-server

# Monitoring Configuration
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PATH=/metrics
JAEGER_ENABLED=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Security Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
ENABLE_CORS=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
ENABLE_AUTHENTICATION=true
ENABLE_AUTHORIZATION=true

# Model Configuration
MAX_MODELS_CACHE=5
MODEL_CACHE_TTL=3600
ENABLE_MODEL_WARMUP=true
MODEL_LOAD_TIMEOUT=300
MODEL_PREDICTION_TIMEOUT=30

# Validation Configuration
ENABLE_INPUT_VALIDATION=true
ENABLE_DRIFT_DETECTION=true
DRIFT_DETECTION_THRESHOLD=0.2
VALIDATION_STRICT_MODE=false

# Feature Flags
ENABLE_CACHING=true
ENABLE_BATCH_PREDICTION=true
ENABLE_MODEL_VERSIONING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RATE_LIMITING=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Performance
ENABLE_ASYNC=true
ENABLE_COMPRESSION=true
MAX_REQUEST_SIZE=10485760

# Kubernetes
K8S_NAMESPACE=model-serving
K8S_SERVICE_ACCOUNT=/var/run/secrets/kubernetes.io/serviceaccount

# Development
DEV_AUTO_RELOAD=true
DEV_LOG_SQL=false
DEV_FAKE_AUTH=false
