# Database Configuration
POSTGRES_USER=mlops
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=churn_prediction
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_ROOT=./mlruns
MLFLOW_S3_ENDPOINT_URL=  # Optional: for S3 artifact storage

# Airflow Configuration
AIRFLOW_HOME=./airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://mlops:change_this_password@localhost:5432/airflow
AIRFLOW__CORE__FERNET_KEY=  # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__WEBSERVER__SECRET_KEY=  # Generate random string
AIRFLOW__CORE__LOAD_EXAMPLES=False

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
MODEL_NAME=churn-predictor
MODEL_VERSION=latest
MODEL_STAGE=Production

# Redis Configuration (for caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Monitoring Configuration
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Feature Store Configuration
FEATURE_STORE_DB=churn_prediction
FEATURE_STORE_SCHEMA=features

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# AWS Configuration (if using S3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=

# Kafka Configuration (if using Kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=customer-events
KAFKA_GROUP_ID=churn-prediction-consumer

# Application Settings
ENVIRONMENT=development  # development, staging, production
DEBUG=True
