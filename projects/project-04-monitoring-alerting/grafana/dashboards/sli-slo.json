{
  "title": "SLI / SLO — Model API",
  "uid": "ml-sli-slo",
  "description": "Service-level indicators vs objectives. Error budget burn-down.",
  "tags": ["ml", "slo", "project-04"],
  "schemaVersion": 38,
  "refresh": "1m",
  "time": {"from": "now-30d", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Availability SLI (30d) — target 99.5%",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 0},
      "targets": [{"expr": "1 - (sum(increase(http_requests_total{job=\"model-api\",status=~\"5..\"}[30d])) / sum(increase(http_requests_total{job=\"model-api\"}[30d])))"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.99},
            {"color": "green", "value": 0.995}
          ]}
        }
      }
    },
    {
      "id": 2,
      "title": "Latency SLI p95 (30d) — target < 800ms",
      "type": "stat",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"model-api\"}[30d])) by (le))"}],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 3,
      "title": "Error budget remaining (30d)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 0},
      "targets": [{"expr": "1 - ((sum(increase(http_requests_total{job=\"model-api\",status=~\"5..\"}[30d])) / sum(increase(http_requests_total{job=\"model-api\"}[30d]))) / 0.005)"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.25},
            {"color": "green", "value": 0.5}
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "Error rate over time (30d)",
      "type": "timeseries",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 6},
      "targets": [{"expr": "sum(rate(http_requests_total{job=\"model-api\",status=~\"5..\"}[1h])) / sum(rate(http_requests_total{job=\"model-api\"}[1h]))", "legendFormat": "error rate"}, {"expr": "0.005", "legendFormat": "SLO threshold"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    }
  ]
}
